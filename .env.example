# Copy these to Vercel → Project → Settings → Environment Variables
# (Production + Preview), then redeploy.

# Workspace address that SENDS the email (From: header)
# Must have 2-Step Verification enabled on the Google account.
GMAIL_USER=leads@onealelectriccompany.com

# App Password from https://myaccount.google.com/apppasswords
# (16 characters, no spaces). NOT the regular login password.
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# Inbox that receives leads. Can be the same as GMAIL_USER,
# or a different address (e.g. dan@onealelectriccompany.com).
CONTACT_TO_EMAIL=dan@onealelectriccompany.com
